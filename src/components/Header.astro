---
import { site } from "../data/site";
import logo from "../assets/logo.png";
import { Image } from "astro:assets";

const path = Astro.url.pathname;
---

<header data-header class="bg-white text-volltar-black sticky top-0 z-50 border-b border-black/10 shadow-sm">
  <div class="h-1 spark-bar" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl flex items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2" aria-label={`${site.name} home`}>
      <Image src={logo} alt={`${site.name} logo`} class="h-10 w-auto" widths={[160, 320]} />
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            aria-current={path === item.href ? "page" : undefined}
            class:list={[
              "hover:text-volltar-orange transition-colors",
              path === item.href ? "text-volltar-orange" : "text-volltar-black/80",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/contact"
      class="hidden md:inline-block bg-volltar-orange text-volltar-black font-semibold text-sm px-4 py-2 rounded-md hover:bg-volltar-orange-light transition-colors"
    >
      Get a Quote
    </a>
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2">
        <span class="sr-only">Menu</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-48 bg-white border border-black/10 rounded-md shadow-lg py-2 flex flex-col z-50">
        {
          site.nav.map((item) => (
            <a href={item.href} class="px-4 py-2 text-sm hover:bg-volltar-offwhite">
              {item.label}
            </a>
          ))
        }
        <a href="/contact" class="px-4 py-2 text-sm text-volltar-orange font-semibold">
          Get a Quote
        </a>
      </div>
    </details>
  </div>
</header>
