---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  title: string;
  subtitle?: string;
  location?: string;
}

const { image, alt, title, subtitle, location } = Astro.props;
---

<section class="relative overflow-hidden" data-reveal>
  <div class="absolute inset-0">
    <Image
      src={image}
      alt={alt}
      class="h-full w-full object-cover scale-105"
      widths={[1200, 1600, 2000]}
      sizes="100vw"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-volltar-black/90 via-volltar-black/70 to-volltar-black/40"></div>
    <div
      class="absolute inset-0 opacity-40 spark-glow mix-blend-soft-light pointer-events-none"
      aria-hidden="true"
    ></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 py-16 md:py-20">
    <div class="max-w-xl">
      {location && (
        <p class="text-volltar-orange text-sm font-semibold uppercase tracking-wide">{location}</p>
      )}
      <p class="font-display text-2xl md:text-3xl font-bold text-white leading-snug mt-1">{title}</p>
      {subtitle && <p class="text-white/75 mt-3 text-lg leading-relaxed">{subtitle}</p>}
    </div>
  </div>
</section>
