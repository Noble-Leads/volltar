---
import { Image } from "astro:assets";
import type { Testimonial } from "../data/testimonials";
import { testimonialAvatars } from "../lib/testimonialAvatars";

interface Props {
  testimonial: Testimonial;
}

const { testimonial } = Astro.props;
const rating = testimonial.rating ?? 5;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
const avatar = testimonialAvatars[testimonial.avatarId];
---

<figure
  data-reveal-item
  data-hover-lift
  data-hover-glow
  class="review-card flex h-full flex-col rounded-xl border border-black/10 bg-white p-6 shadow-sm"
>
  <div class="mb-4 flex items-start justify-between gap-3">
    <div class="flex gap-0.5 text-volltar-orange" role="img" aria-label={`${rating} out of 5 stars`}>
      {
        stars.map((filled) => (
          <span class={filled ? "" : "text-black/15"} aria-hidden="true">
            ★
          </span>
        ))
      }
    </div>
    <span class="shrink-0 rounded-full bg-volltar-offwhite px-2.5 py-0.5 text-xs font-medium text-black/55">
      {testimonial.service}
    </span>
  </div>

  <blockquote class="flex-1 text-sm leading-relaxed text-black/80">
    &ldquo;{testimonial.quote}&rdquo;
  </blockquote>

  <figcaption class="mt-5 flex items-center gap-3 border-t border-black/8 pt-5">
    <Image
      src={avatar}
      alt=""
      aria-hidden="true"
      class="h-11 w-11 shrink-0 rounded-full object-cover ring-2 ring-white shadow-sm"
      widths={[44, 88, 128]}
      width={44}
      height={44}
      loading="lazy"
    />
    <div class="min-w-0">
      <span class="block text-sm font-semibold">{testimonial.name}</span>
      <span class="block text-xs text-black/50">{testimonial.location}</span>
      <span class="mt-0.5 block text-xs text-black/40">Local customer</span>
    </div>
  </figcaption>
</figure>
