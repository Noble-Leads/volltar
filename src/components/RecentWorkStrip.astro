---
import { Image } from "astro:assets";
import { getRecentWorkPhotos } from "../data/recentWork";

const photos = getRecentWorkPhotos();
---

<section class="border-y border-black/10 bg-white py-10 md:py-12 overflow-hidden">
  <div class="mx-auto max-w-6xl px-4 mb-6 flex items-end justify-between gap-4 flex-wrap">
    <div>
      <p class="text-volltar-orange text-sm font-semibold uppercase tracking-wide">From recent jobs</p>
      <h2 class="font-display text-xl md:text-2xl font-bold mt-1">Real work, not stock photos</h2>
    </div>
    <a href="/portfolio" class="text-sm font-semibold text-volltar-orange hover:underline shrink-0">
      All case studies &rarr;
    </a>
  </div>

  <div class="flex gap-4 overflow-x-auto pb-2 px-4 snap-x snap-mandatory scrollbar-thin md:px-[max(1rem,calc((100vw-72rem)/2+1rem))]">
    {
      photos.map((photo) => (
        <figure
          class="group relative shrink-0 w-56 sm:w-64 snap-start overflow-hidden rounded-xl border border-black/10 bg-volltar-offwhite shadow-sm"
          data-reveal-item
        >
          <Image
            src={photo.src}
            alt={photo.alt}
            class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
            widths={[256, 384]}
            sizes="256px"
            loading="lazy"
          />
          <figcaption class="p-3">
            {photo.location && (
              <p class="text-[10px] font-bold uppercase tracking-wide text-volltar-orange">{photo.location}</p>
            )}
            <p class="text-xs text-black/70 mt-0.5 line-clamp-2 leading-snug">{photo.caption}</p>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--color-volltar-orange) 40%, transparent) transparent;
  }
</style>
