---
import TestimonialCard from "./TestimonialCard.astro";
import type { Testimonial } from "../data/testimonials";
import { averageRating } from "../data/testimonials";

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
const avg = averageRating(testimonials);
---

<section class="border-y border-black/5 bg-white py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mb-10 flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
      <div class="max-w-xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-volltar-orange">Customer reviews</p>
        <h2 class="font-display mt-1 text-2xl font-bold md:text-3xl">What customers say</h2>
        <p class="mt-2 text-black/60">
          Honest feedback from homeowners across Chesterfield, Leicester, Wellingborough and nearby.
        </p>
      </div>

      <div
        class="inline-flex items-center gap-4 self-start rounded-xl border border-black/10 bg-volltar-offwhite px-5 py-4 shadow-sm md:self-auto"
        aria-label={`Average rating ${avg} out of 5`}
      >
        <span class="font-display text-3xl font-bold leading-none">{avg.toFixed(1)}</span>
        <div>
          <div class="flex gap-0.5 text-volltar-orange text-sm" aria-hidden="true">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="mt-1 text-xs text-black/50">From recent local jobs</p>
        </div>
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
      {testimonials.map((testimonial) => <TestimonialCard testimonial={testimonial} />)}
    </div>
  </div>
</section>
