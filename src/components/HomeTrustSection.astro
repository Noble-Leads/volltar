---
import { values } from "../data/site";

const portfolioHighlights = [
  "CCTV & network installs",
  "Kitchen tiling & sockets",
  "Loft boarding & lighting",
];
---

<section class="bg-volltar-black text-white spark-glow border-y border-white/10">
  <div class="h-1 spark-bar" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-start">
      <div class="lg:col-span-5" data-reveal>
        <p class="text-volltar-orange text-sm font-semibold uppercase tracking-wide">How I work</p>
        <h2 class="font-display text-2xl md:text-3xl font-bold mt-2 leading-tight">
          Careful work, clearly explained.
        </h2>
        <p class="text-white/70 mt-4 leading-relaxed">
          The portfolio has real write-ups with photos from completed jobs — kitchens, CCTV, loft work and more.
          Worth a look if you want to see how things are finished before you get in touch.
        </p>

        <ul class="mt-6 space-y-2">
          {
            portfolioHighlights.map((item) => (
              <li class="flex items-center gap-2 text-sm text-white/80">
                <span class="text-volltar-orange">&#9679;</span>
                {item}
              </li>
            ))
          }
        </ul>

        <a
          href="/portfolio"
          class="mt-8 inline-flex items-center gap-2 rounded-lg bg-volltar-orange px-5 py-2.5 text-sm font-semibold text-volltar-black transition-colors hover:bg-volltar-orange-light"
        >
          Browse the portfolio
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="lg:col-span-7 grid sm:grid-cols-3 gap-4" data-reveal-stagger>
        {
          values.map((value) => (
            <div
              data-reveal-item
              class="rounded-xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm"
            >
              <h3 class="font-display font-bold text-sm leading-snug">{value.title}</h3>
              <p class="text-sm text-white/65 mt-2 leading-relaxed">{value.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
