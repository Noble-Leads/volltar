---
import { processSteps } from "../data/process";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "How it works",
  description = "Straightforward from first message to finished job.",
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-16 md:py-20" data-process-steps>
  <div class="max-w-2xl" data-reveal>
    <h2 class="font-display text-2xl md:text-3xl font-bold">{title}</h2>
    <p class="text-black/60 mt-2 text-lg">{description}</p>
  </div>

  <div class="mt-12 relative" data-process-track>
    <div
      class="process-line hidden md:block absolute top-7 left-[calc(12.5%+1.25rem)] right-[calc(12.5%+1.25rem)] h-1 rounded-full bg-black/[0.08] overflow-hidden"
      aria-hidden="true"
    >
      <div
        data-process-line-fill
        class="h-full w-full rounded-full bg-gradient-to-r from-volltar-orange/50 via-volltar-orange to-volltar-orange/50"
      ></div>
    </div>

    <div
      class="process-line-mobile md:hidden absolute left-[1.2rem] top-5 bottom-5 w-1 rounded-full bg-black/[0.08] overflow-hidden"
      aria-hidden="true"
    >
      <div data-process-line-fill-mobile class="h-full w-full rounded-full bg-volltar-orange"></div>
    </div>

    <ol class="grid md:grid-cols-4 gap-8 md:gap-5 relative">
      {
        processSteps.map((step, index) => (
          <li data-process-step class="relative pl-14 md:pl-0">
            <article
              data-process-card
              class="process-step-card group rounded-2xl border border-black/10 bg-white p-5 md:px-5 md:pb-6 md:pt-10 shadow-sm h-full cursor-default"
            >
              <span
                data-process-badge
                class="process-step-badge absolute left-0 md:left-1/2 md:-translate-x-1/2 md:-top-5 top-0 inline-flex items-center justify-center h-10 w-10 rounded-full bg-volltar-orange text-volltar-black font-extrabold text-sm shadow-sm ring-4 ring-volltar-offwhite"
              >
                {String(index + 1).padStart(2, "0")}
              </span>
              <h3 class="font-display font-bold text-lg">{step.title}</h3>
              <p class="text-sm text-black/70 mt-2 leading-relaxed">{step.description}</p>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
