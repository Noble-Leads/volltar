---
import { Image } from "astro:assets";
import type { Service } from "../data/services";
import { focusAreas } from "../data/handymanRange";
import { getPortfolioJob } from "../data/portfolio";
import { getServiceCardImage } from "../lib/serviceImages";
import Icon from "./Icon.astro";

interface Props {
  service: Service;
}

const { service } = Astro.props;
const job = service.portfolioSlug ? getPortfolioJob(service.portfolioSlug) : undefined;
const img = service.cardImage ? getServiceCardImage(service.cardImage) : undefined;
const jobHref = job ? `/portfolio/${job.slug}` : undefined;
---

<section id="focus" class="scroll-mt-20 bg-volltar-black text-white spark-glow border-y border-white/10">
  <div class="h-1 spark-bar" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <div class="lg:col-span-5 order-2 lg:order-1" data-reveal>
        <p class="text-volltar-orange text-sm font-semibold uppercase tracking-wide">Where I focus most</p>
        <div class="inline-flex items-center justify-center h-12 w-12 rounded-lg bg-volltar-orange text-volltar-black mt-4 mb-5">
          <Icon name={service.icon} class="h-6 w-6" />
        </div>
        <h2 class="font-display text-2xl md:text-3xl font-bold leading-tight">{service.title}</h2>
        <p class="mt-4 text-white/75 leading-relaxed text-lg">{service.blurb}</p>

        <ul class="mt-6 flex flex-wrap gap-2">
          {
            focusAreas.map((item) => (
              <li class="rounded-full border border-volltar-orange/30 bg-volltar-orange/10 px-3 py-1 text-xs font-medium text-volltar-orange-light">
                {item}
              </li>
            ))
          }
        </ul>

        <ul class="mt-8 space-y-2 border-t border-white/10 pt-6">
          {
            service.examples.map((example) => (
              <li class="text-sm flex items-start gap-2 text-white/80">
                <span class="text-volltar-orange shrink-0">&#10003;</span>
                {example}
              </li>
            ))
          }
        </ul>

        {
          jobHref && (
            <a
              href={jobHref}
              class="mt-8 inline-flex items-center gap-2 rounded-lg bg-volltar-orange px-5 py-2.5 text-sm font-semibold text-volltar-black transition-colors hover:bg-volltar-orange-light"
            >
              View {job?.location} CCTV install
              <span aria-hidden="true">&rarr;</span>
            </a>
          )
        }
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2" data-reveal>
        {
          img && (
            <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-2xl" data-reveal-image>
              <Image
                src={img}
                alt={job?.title ?? service.title}
                class="w-full aspect-[4/3] object-cover"
                widths={[600, 900, 1200]}
                sizes="(max-width: 1024px) 100vw, 58vw"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-volltar-black/50 via-transparent to-transparent pointer-events-none"></div>
              {job && (
                <span class="absolute bottom-4 left-4 text-xs font-bold uppercase tracking-wide bg-volltar-orange text-volltar-black px-2.5 py-1 rounded-full">
                  Real job — {job.location}
                </span>
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
