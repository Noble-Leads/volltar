---
import { Image } from "astro:assets";
import type { Service } from "../data/services";
import { getPortfolioJob } from "../data/portfolio";
import { getPortfolioImage } from "../lib/portfolioImages";
import { getServiceCardImage } from "../lib/serviceImages";
import Icon from "./Icon.astro";

interface Props {
  service: Service;
  variant?: "default" | "featured";
}

const { service, variant = "default" } = Astro.props;
const job = service.portfolioSlug ? getPortfolioJob(service.portfolioSlug) : undefined;
const img =
  (service.cardImage ? getServiceCardImage(service.cardImage) : undefined) ??
  (job ? getPortfolioImage(job.image) : undefined);
const jobHref = job ? `/portfolio/${job.slug}` : undefined;
const imgAlt = job?.title ?? service.title;

const cardClass = service.featured
  ? "bg-volltar-black text-white border-volltar-orange"
  : "bg-white text-volltar-black border-black/10";

const iconClass = service.featured
  ? "bg-volltar-orange text-volltar-black"
  : "bg-volltar-orange/10 text-volltar-orange";
---

{
  variant === "featured" && img ? (
    <a
      href={jobHref ?? `/services#${service.slug}`}
      data-reveal-item
      data-hover-lift
      class:list={[
        "group grid md:grid-cols-2 overflow-hidden rounded-2xl border transition-shadow hover:shadow-xl",
        cardClass,
      ]}
    >
      <div class="relative overflow-hidden min-h-[14rem] md:min-h-0">
        <Image
          src={img}
          alt={imgAlt}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          widths={[480, 720, 960]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-volltar-black/60 via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:via-transparent md:to-volltar-black/30"></div>
        {job && (
          <span class="absolute top-4 left-4 text-xs font-bold uppercase tracking-wide bg-volltar-orange text-volltar-black px-2.5 py-1 rounded-full">
            Case study
          </span>
        )}
      </div>
      <div class="p-6 md:p-8 flex flex-col justify-center">
        <span class="text-xs font-bold uppercase tracking-wide text-volltar-orange mb-2">Specialty</span>
        <div class:list={["inline-flex items-center justify-center h-11 w-11 rounded-lg mb-4", iconClass]}>
          <Icon name={service.icon} class="h-5 w-5" />
        </div>
        <h3 class="font-display text-xl md:text-2xl font-bold">{service.title}</h3>
        <p class="mt-2 text-white/80 leading-relaxed">{service.blurb}</p>
        {jobHref && (
          <span class="mt-5 text-sm font-semibold text-volltar-orange inline-flex items-center gap-1">
            See the {job?.location} install
            <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </span>
        )}
      </div>
    </a>
  ) : (
    <div
      data-reveal-item
      data-hover-lift
      class:list={["group rounded-xl border overflow-hidden transition-shadow hover:shadow-md", cardClass]}
    >
      {
        img && (
          <a href={jobHref} class="block relative overflow-hidden h-32">
            <Image
              src={img}
              alt={imgAlt}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              widths={[320, 480]}
              sizes="(max-width: 768px) 100vw, 320px"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </a>
        )
      }
      <div class="p-5">
        <div class:list={["inline-flex items-center justify-center h-10 w-10 rounded-lg mb-3", iconClass]}>
          <Icon name={service.icon} class="h-5 w-5" />
        </div>
        {service.featured && (
          <span class="block text-xs font-bold uppercase tracking-wide text-volltar-orange mb-1">Specialty</span>
        )}
        <h3 class="font-display text-lg font-bold">{service.title}</h3>
        <p class:list={["text-sm mt-2 leading-relaxed", service.featured ? "text-white/80" : "text-black/70"]}>
          {service.blurb}
        </p>
        <a
          href={`/services#${service.slug}`}
          class="mt-3 inline-block text-xs font-semibold text-volltar-orange hover:underline"
        >
          Learn more
        </a>
      </div>
    </div>
  )
}
