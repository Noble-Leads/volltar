---
import { site } from "../data/site";
---

<footer class="bg-volltar-charcoal text-white mt-24">
  <div class="h-1 spark-bar" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl px-4 py-12 grid gap-8 md:grid-cols-3">
    <div>
      <p class="text-xl font-bold">{site.name}</p>
      <p class="text-sm text-white/70 mt-1">{site.tagline}</p>
      <p class="text-sm text-white/70 mt-4">{site.areaBlurb}</p>
    </div>
    <div>
      <p class="font-semibold mb-2">Get in touch</p>
      <ul class="text-sm text-white/70 space-y-1">
        <li><a href={site.phoneHref} class="hover:text-volltar-orange">{site.phone}</a></li>
        <li><a href={site.whatsappHref} class="hover:text-volltar-orange">WhatsApp</a></li>
        <li><a href={`mailto:${site.email}`} class="hover:text-volltar-orange">{site.email}</a></li>
      </ul>
      <p class="text-sm text-white/50 mt-4">{site.availabilitySummary}</p>
    </div>
    <div>
      <p class="font-semibold mb-2">Explore</p>
      <ul class="text-sm text-white/70 space-y-1">
        {
          site.nav.map((item) => (
            <li>
              <a href={item.href} class="hover:text-volltar-orange">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 text-center text-xs text-white/40 py-4 space-y-1">
    <p>&copy; {new Date().getFullYear()} {site.name}. All rights reserved.</p>
    <p>Site updated {new Date().toLocaleDateString("en-GB", { month: "long", year: "numeric" })}</p>
    <p>
      Powered by{" "}
      <a
        href="https://nobleleads.uk"
        class="text-white/50 transition-colors hover:text-white/70"
        rel="noopener noreferrer"
        target="_blank"
      >
        Noble<span class="text-[#C5A55A]">Leads</span>
      </a>
    </p>
  </div>
</footer>
