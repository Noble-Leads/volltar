---
import { site } from "../data/site";
---

<section class="bg-volltar-offwhite border-y border-black/10" data-reveal-fade>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <p class="text-center text-sm font-semibold text-volltar-black mb-4">Areas covered</p>
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-black/70">
      {site.areas.map((area) => (
        <span class="flex items-center gap-2">
          <span class="text-volltar-orange">&#9679;</span>
          {area}
        </span>
      ))}
      {site.moreAreas.map((area) => (
        <span class="flex items-center gap-2">
          <span class="text-volltar-blue">&#9679;</span>
          {area}
        </span>
      ))}
    </div>
    <p class="text-center text-xs text-black/50 mt-4 max-w-2xl mx-auto">{site.areaBlurb}</p>
  </div>
</section>
