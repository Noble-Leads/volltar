---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { portfolioJobs } from "../../data/portfolio";
import { getPortfolioImage } from "../../lib/portfolioImages";

export async function getStaticPaths() {
  return portfolioJobs.map((job) => ({
    params: { slug: job.slug },
    props: { job },
  }));
}

const { job } = Astro.props;

const currentIndex = portfolioJobs.findIndex((j) => j.slug === job.slug);
const nextJob = portfolioJobs[(currentIndex + 1) % portfolioJobs.length];

const cover = getPortfolioImage(job.image);
const gallery = job.gallery
  .map((item) => ({ ...item, resolved: getPortfolioImage(item.src) }))
  .filter((item) => item.resolved);
---

<BaseLayout title={`${job.title} | Case Study`} description={job.summary}>
  <article>
    <!-- Hero -->
    <header class="bg-volltar-black text-white spark-glow">
      <div class="mx-auto max-w-6xl px-4 py-14 grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <a href="/portfolio" class="text-sm text-white/60 hover:text-volltar-orange transition-colors">
            &larr; Back to portfolio
          </a>
          <span class="block mt-6 text-xs font-bold uppercase tracking-wide text-volltar-orange">
            {job.serviceTag}
          </span>
          <h1 class="text-3xl md:text-4xl font-extrabold mt-2 leading-tight">{job.title}</h1>
          <p class="text-white/70 mt-4 text-lg">{job.summary}</p>
          <dl class="mt-8 grid grid-cols-2 gap-4">
            {
              job.facts.map((fact) => (
                <div class="border-l-2 border-volltar-orange/60 pl-3">
                  <dt class="text-xs uppercase tracking-wide text-white/50">{fact.label}</dt>
                  <dd class="text-sm font-semibold mt-0.5">{fact.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>
        {
          cover && (
            <div class="rounded-2xl overflow-hidden border border-white/10">
              <Image
                src={cover}
                alt={job.title}
                class="w-full h-72 lg:h-96 object-cover"
                widths={[600, 1000]}
                sizes="(max-width: 1024px) 100vw, 600px"
              />
            </div>
          )
        }
      </div>
    </header>

    <!-- Write-up -->
    <div class="mx-auto max-w-3xl px-4 py-16">
      <section>
        <h2 class="text-sm font-bold uppercase tracking-wide text-volltar-orange">The challenge</h2>
        <p class="text-lg text-black/80 mt-3 leading-relaxed">{job.challenge}</p>
      </section>

      <section class="mt-12">
        <h2 class="text-sm font-bold uppercase tracking-wide text-volltar-orange">The approach</h2>
        <div class="mt-3 space-y-4">
          {job.approach.map((para) => <p class="text-black/80 leading-relaxed">{para}</p>)}
        </div>
      </section>

      <section class="mt-12">
        <h2 class="text-sm font-bold uppercase tracking-wide text-volltar-orange">The result</h2>
        <p class="text-lg text-black/80 mt-3 leading-relaxed">{job.result}</p>
      </section>
    </div>

    <!-- Gallery -->
    {
      gallery.length > 0 && (
        <div class="bg-volltar-offwhite border-y border-black/10">
          <div class="mx-auto max-w-6xl px-4 py-16">
            <h2 class="text-2xl font-bold">Photos from the job</h2>
            <div class="grid sm:grid-cols-2 gap-6 mt-8">
              {gallery.map((item) => (
                <figure class="bg-white rounded-xl overflow-hidden border border-black/10">
                  <Image
                    src={item.resolved!}
                    alt={item.alt}
                    class="w-full h-64 object-cover"
                    widths={[500, 1000]}
                    sizes="(max-width: 768px) 100vw, 500px"
                  />
                  {item.caption && (
                    <figcaption class="text-sm text-black/60 px-4 py-3">{item.caption}</figcaption>
                  )}
                </figure>
              ))}
            </div>
          </div>
        </div>
      )
    }

    <!-- CTA + next -->
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="bg-volltar-black text-white rounded-2xl p-8 md:p-10 grid md:grid-cols-2 gap-6 items-center spark-glow">
        <div>
          <h2 class="text-2xl font-bold">Got a similar job in mind?</h2>
          <p class="text-white/70 mt-2">
            Tell me what you need and I'll let you know how I can help. Photos of the job are always useful.
          </p>
        </div>
        <div class="flex md:justify-end">
          <a
            href="/contact"
            class="bg-volltar-orange text-volltar-black font-semibold px-6 py-3 rounded-md hover:bg-volltar-orange-light transition-colors"
          >
            Get a Quote
          </a>
        </div>
      </div>

      {
        nextJob && nextJob.slug !== job.slug && (
          <a
            href={`/portfolio/${nextJob.slug}`}
            class="mt-8 flex items-center justify-between rounded-xl border border-black/10 bg-white px-6 py-5 hover:border-volltar-orange/50 hover:shadow-md transition-all group"
          >
            <span>
              <span class="block text-xs uppercase tracking-wide text-black/50">Next in portfolio</span>
              <span class="block font-bold mt-1 group-hover:text-volltar-orange transition-colors">
                {nextJob.title}
              </span>
            </span>
            <span class="text-volltar-orange text-xl transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        )
      }
    </div>
  </article>
</BaseLayout>
